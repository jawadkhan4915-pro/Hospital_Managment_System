# ============================================================
# Enterprise HMS — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Local:      mongodb://127.0.0.1:27017/hms
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hms?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/hms

# --- Auth ---
# Use a long, random string for production (min 32 chars)
JWT_SECRET=your_strong_jwt_secret_here

# --- CORS (production only) ---
# Set this to your Vercel frontend URL, e.g. https://enterprise-hms.vercel.app
# Leave empty in development
FRONTEND_URL=
